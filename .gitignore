# =============================================================
# SECRETS — never commit credentials or environment config
# =============================================================
.env
.env.*

# =============================================================
# PYTHON — compiled files and cache (auto-generated, not needed)
# =============================================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyc

# =============================================================
# VIRTUAL ENVIRONMENT — each developer has their own
# =============================================================
.venv/
venv/
env/

# =============================================================
# EDITOR / IDE — personal workspace settings, not project files
# =============================================================
.vscode/
.idea/

# =============================================================
# PERSONAL / LOCAL FILES — notes and tools not part of the codebase
# =============================================================
Gym.txt
step.md
PROJECT_STRUCTURE.md
ABOUT.md
AGENTS.md
AWS.md
task2.md
.claude/
.beads/

# =============================================================
# BUILD / PACKAGING — generated when running pip install -e .
# =============================================================
*.egg-info/
dist/
build/

# =============================================================
# LOGS — runtime output files, not source code
# =============================================================
*.log

# =============================================================
# TESTING — pytest cache and coverage reports
# =============================================================
.pytest_cache/
htmlcov/
.coverage

# =============================================================
# LOCAL DATABASES — SQLite files sometimes created during dev/tests
# =============================================================
*.db
*.sqlite3

# Beads / Dolt files (added by bd init)
.dolt/
.beads-credential-key
.beads/
